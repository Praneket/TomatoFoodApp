{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@tomato/shared-types": ["packages/shared-types/src"],
      "@tomato/utils": ["packages/utils/src"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}

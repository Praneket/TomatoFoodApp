# ============================================================
# TOMATO PLATFORM - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- NODE ---
NODE_ENV=development

# --- API GATEWAY ---
GATEWAY_PORT=3000
GATEWAY_SECRET=your_gateway_secret_here

# --- AUTH SERVICE ---
AUTH_SERVICE_PORT=3001
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# --- USER SERVICE ---
USER_SERVICE_PORT=3002

# --- RESTAURANT SERVICE ---
RESTAURANT_SERVICE_PORT=3003

# --- CATALOG SERVICE ---
CATALOG_SERVICE_PORT=3004

# --- CART SERVICE ---
CART_SERVICE_PORT=3005

# --- ORDER SERVICE ---
ORDER_SERVICE_PORT=3006

# --- PAYMENT SERVICE ---
PAYMENT_SERVICE_PORT=3007
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# --- DELIVERY SERVICE ---
DELIVERY_SERVICE_PORT=3008
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# --- NOTIFICATION SERVICE ---
NOTIFICATION_SERVICE_PORT=3009
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
FCM_SERVER_KEY=your_firebase_server_key

# --- REVIEW SERVICE ---
REVIEW_SERVICE_PORT=3010

# --- AI SERVICE ---
AI_SERVICE_PORT=8000
OPENAI_API_KEY=your_openai_api_key

# --- ANALYTICS SERVICE ---
ANALYTICS_SERVICE_PORT=3011

# --- DATABASES ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tomato_user
POSTGRES_PASSWORD=tomato_password
POSTGRES_DB=tomato_db
DATABASE_URL=postgresql://tomato_user:tomato_password@localhost:5432/tomato_db

MONGO_URI=mongodb://localhost:27017/tomato
REDIS_URL=redis://localhost:6379

# --- MESSAGE BROKER ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# --- FRONTEND URLS ---
CUSTOMER_APP_URL=http://localhost:5173
ADMIN_PANEL_URL=http://localhost:5174
DELIVERY_APP_URL=http://localhost:5175
SUPER_ADMIN_URL=http://localhost:5176

# --- SUPABASE (Image Upload + Storage) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- MONITORING ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
